# QRBuddy Environment Variables

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Edge functions need the service role key inside Supabase secrets.
# Do not expose this key to the Fresh app or client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public URL used inside edge functions when generating share links
# Set to https://qrbuddy.app in production or http://localhost:8004 when testing locally
APP_URL=https://qrbuddy.app
